#!/usr/bin/env python3

import argparse
from pathlib import Path
from os.path import dirname, isdir

from tts_encoders import StyleBertVits2Encoder


def parse_arguments():
    parser = argparse.ArgumentParser()
    parser.add_argument("--save-path", type=str, required=True, help="The path to save the converted GGUF model.")
    parser.add_argument("--model-dir", type=str, help="Directory containing a Style-Bert-VITS2 model, config, and style vectors.")
    parser.add_argument("--model-path", type=str, help="Path to a Style-Bert-VITS2 .safetensors or .pth model.")
    parser.add_argument("--config-path", type=str, help="Path to Style-Bert-VITS2 config.json.")
    parser.add_argument("--style-vec-path", type=str, help="Path to style_vectors.npy.")
    parser.add_argument("--device", type=str, default="cpu", help="Device used while loading the PyTorch reference model.")
    parser.add_argument("--never-make-dirs", default=False, action="store_true", help="Never create output directories.")
    return parser.parse_known_args()


def resolve_paths(args):
    model_dir = Path(args.model_dir).expanduser() if args.model_dir else None
    model_path = Path(args.model_path).expanduser() if args.model_path else None
    config_path = Path(args.config_path).expanduser() if args.config_path else None
    style_vec_path = Path(args.style_vec_path).expanduser() if args.style_vec_path else None

    if model_dir is not None:
        config_path = config_path or model_dir / "config.json"
        style_vec_path = style_vec_path or model_dir / "style_vectors.npy"
        if model_path is None:
            candidates = sorted(model_dir.glob("*.safetensors")) + sorted(model_dir.glob("*.pth"))
            if candidates:
                model_path = candidates[0]

    missing = [
        name
        for name, value in {
            "model_path": model_path,
            "config_path": config_path,
            "style_vec_path": style_vec_path,
        }.items()
        if value is None or not value.exists()
    ]
    if missing:
        raise ValueError(f"Missing Style-Bert-VITS2 input paths: {', '.join(missing)}")
    return model_path, config_path, style_vec_path


if __name__ == "__main__":
    args, _ = parse_arguments()
    if not isdir(dirname(args.save_path)) and args.never_make_dirs:
        raise ValueError(f"model path, {args.save_path} is not a valid path.")
    model_path, config_path, style_vec_path = resolve_paths(args)
    StyleBertVits2Encoder(
        args.save_path,
        source_model_path=model_path,
        config_path=config_path,
        style_vec_path=style_vec_path,
        device=args.device,
    ).write()
